# LoanAgent Backend Configuration
# Copy this to .env and update values as needed

# ============================================================================
# OLLAMA / LLM INFERENCE
# ============================================================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TIMEOUT=120
OLLAMA_MAX_RETRIES=3

# ============================================================================
# EMBEDDINGS
# ============================================================================
EMBED_MODEL=paraphrase-multilingual-MiniLM-L12-v2
EMBED_BATCH_SIZE=32

# ============================================================================
# STORAGE PATHS
# ============================================================================
SQLITE_PATH=./data/memory.db
CHROMA_PATH=./data/chroma_db

# ============================================================================
# ENCRYPTION
# ============================================================================
DB_ENCRYPTION_KEY=

# ============================================================================
# AUTHENTICATION
# ============================================================================
JWT_EXPIRES_HOURS=24
JWT_SECRET=

# ============================================================================
# MEMORY THRESHOLDS & LIMITS
# ============================================================================
TOKEN_THRESHOLD=2000
SESSION_CONTEXT_WINDOW=4096
MAX_SESSION_TURNS=50
VECTOR_SEARCH_TOP_K=5
TOKEN_THRESHOLD_PERCENT=0.80
TOKEN_TARGET_PERCENT=0.50

# ============================================================================
# LANGUAGE & NLP
# ============================================================================
DEFAULT_LANGUAGE=en
ENABLE_HINDI_SUPPORT=true

# ============================================================================
# LANGSMITH OBSERVABILITY
# ============================================================================
LANGCHAIN_API_KEY=
LANGSMITH_TRACING_V2=true
LANGSMITH_PROJECT=

# ============================================================================
# LOGGING & DEBUG
# ============================================================================
DEBUG=false
LOG_LEVEL=INFO
